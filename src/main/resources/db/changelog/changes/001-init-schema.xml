<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-init-schema" author="codex">
        <createTable tableName="genres">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_genres"/>
            </column>
            <column name="title" type="VARCHAR(100)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_genres_title"/>
            </column>
        </createTable>

        <createTable tableName="authors">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_authors"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="bio" type="TEXT"/>
        </createTable>

        <createTable tableName="users">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_users"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_users_email"/>
            </column>
            <column name="password_hash" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="full_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="profile_image_url" type="VARCHAR(512)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="books">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_books"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="cover_image_url" type="VARCHAR(512)"/>
            <column name="genre_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="pdf_url" type="VARCHAR(1024)"/>
            <column name="publication_year" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="comments">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_comments"/>
            </column>
            <column name="book_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="text" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="book_authors">
            <column name="book_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="author_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="book_authors"
                       columnNames="book_id,author_id"
                       constraintName="pk_book_authors"/>

        <createTable tableName="user_liked_books">
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="book_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="user_liked_books"
                       columnNames="user_id,book_id"
                       constraintName="pk_user_liked_books"/>

        <createTable tableName="user_disliked_books">
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="book_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="user_disliked_books"
                       columnNames="user_id,book_id"
                       constraintName="pk_user_disliked_books"/>

        <createTable tableName="user_saved_books">
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="book_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="user_saved_books"
                       columnNames="user_id,book_id"
                       constraintName="pk_user_saved_books"/>

        <addForeignKeyConstraint baseTableName="books"
                                 baseColumnNames="genre_id"
                                 referencedTableName="genres"
                                 referencedColumnNames="id"
                                 constraintName="fk_books_genre"/>

        <addForeignKeyConstraint baseTableName="comments"
                                 baseColumnNames="book_id"
                                 referencedTableName="books"
                                 referencedColumnNames="id"
                                 constraintName="fk_comments_book"/>

        <addForeignKeyConstraint baseTableName="comments"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 constraintName="fk_comments_user"/>

        <addForeignKeyConstraint baseTableName="book_authors"
                                 baseColumnNames="book_id"
                                 referencedTableName="books"
                                 referencedColumnNames="id"
                                 constraintName="fk_book_authors_book"/>

        <addForeignKeyConstraint baseTableName="book_authors"
                                 baseColumnNames="author_id"
                                 referencedTableName="authors"
                                 referencedColumnNames="id"
                                 constraintName="fk_book_authors_author"/>

        <addForeignKeyConstraint baseTableName="user_liked_books"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 constraintName="fk_user_liked_books_user"/>

        <addForeignKeyConstraint baseTableName="user_liked_books"
                                 baseColumnNames="book_id"
                                 referencedTableName="books"
                                 referencedColumnNames="id"
                                 constraintName="fk_user_liked_books_book"/>

        <addForeignKeyConstraint baseTableName="user_disliked_books"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 constraintName="fk_user_disliked_books_user"/>

        <addForeignKeyConstraint baseTableName="user_disliked_books"
                                 baseColumnNames="book_id"
                                 referencedTableName="books"
                                 referencedColumnNames="id"
                                 constraintName="fk_user_disliked_books_book"/>

        <addForeignKeyConstraint baseTableName="user_saved_books"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 constraintName="fk_user_saved_books_user"/>

        <addForeignKeyConstraint baseTableName="user_saved_books"
                                 baseColumnNames="book_id"
                                 referencedTableName="books"
                                 referencedColumnNames="id"
                                 constraintName="fk_user_saved_books_book"/>

        <createIndex tableName="books" indexName="idx_books_genre_id">
            <column name="genre_id"/>
        </createIndex>

        <createIndex tableName="comments" indexName="idx_comments_book_id">
            <column name="book_id"/>
        </createIndex>

        <createIndex tableName="comments" indexName="idx_comments_user_id">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
