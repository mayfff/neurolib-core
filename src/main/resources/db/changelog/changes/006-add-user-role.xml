<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="006-add-user-role-column" author="codex">
        <addColumn tableName="users">
            <column name="role" type="VARCHAR(20)" defaultValue="USER"/>
        </addColumn>
    </changeSet>

    <changeSet id="006-fill-user-role" author="codex">
        <update tableName="users">
            <column name="role" value="USER"/>
            <where>role IS NULL</where>
        </update>
    </changeSet>

    <changeSet id="006-user-role-not-null" author="codex">
        <addNotNullConstraint tableName="users" columnName="role" columnDataType="VARCHAR(20)"/>
    </changeSet>

</databaseChangeLog>
